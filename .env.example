# HeartSync Environment Variables
# Copy this file to .env and update the values

# Security
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=False

# Database
DATABASE_PATH=app/database/heartsync.db

# Application
APP_NAME=HeartSync
APP_VERSION=1.0.0

# Anniversary Date (YYYY-MM-DD)
ANNIVERSARY_DATE=2024-01-01

# Passphrase for authentication
USER_A_NAME=taotao
USER_B_NAME=fangfang
USER_A_PASSPHRASE=fangfang
